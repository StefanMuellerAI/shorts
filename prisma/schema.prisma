generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL")
}

enum Role {
  ADMIN
  USER
}

enum SourceType {
  LINK
  SCREENSHOT
}

enum Status {
  VORRAT
  ABGEDREHT
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  name      String
  password  String
  role      Role        @default(USER)
  ideas     ShortIdea[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Category {
  id        String      @id @default(cuid())
  name      String      @unique
  color     String      @default("#6366f1")
  ideas     ShortIdea[]
  createdAt DateTime    @default(now())
}

model ShortIdea {
  id            String     @id @default(cuid())
  hook          String[]
  kernaussage   String[]
  meinTake      String[]
  categoryId    String?
  category      Category?  @relation(fields: [categoryId], references: [id])
  sourceType    SourceType
  sourceUrl     String?
  screenshotUrl String?
  status        Status     @default(VORRAT)
  sortOrder     Int        @default(0)
  createdById   String
  createdBy     User       @relation(fields: [createdById], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([createdById])
  @@index([sortOrder])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}
